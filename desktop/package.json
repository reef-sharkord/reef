{
  "name": "reef-desktop",
  "version": "0.1.1",
  "private": true,
  "description": "REEF desktop shell (auto-updating Electron app)",
  "author": "REEF",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "bun scripts/patch-source-map-support.mjs",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "cd ../apps/client && cross-env VITE_STANDALONE=true bun run vite build --base=./ --outDir ../../desktop/renderer --emptyOutDir",
    "build": "npm run build:renderer && npm run build:main",
    "dev:main": "tsc -p tsconfig.json -w",
    "dev": "concurrently \"npm:dev:main\" \"electron .\"",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "publish": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "uiohook-napi": "^1.5.5"
  },
  "trustedDependencies": [
    "electron",
    "electron-builder",
    "app-builder-bin",
    "7zip-bin",
    "dmg-license"
  ],
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3"
  }
}
