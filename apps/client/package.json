    "filesize": "^11.0.13",
    "html-react-parser": "^5.2.6",
    "i18next": "^25.8.14",
    "i18next-resources-to-backend": "^1.2.1",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.544.0",
    "mediasoup-client": "^3.18.0",
    "prosemirror-view": "^1.41.6",
    "re-reselect": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^16.5.6",
